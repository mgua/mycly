# mycly environment configuration
# Copy this file to .env and fill in your values
# .env is gitignored — it never goes to the repo

# ---- Inference Backend ----
# URL of an Anthropic Messages API-compatible endpoint
# Examples:
#   Ollama:       http://localhost:11434
#   vLLM:         http://inference.internal:8000/v1
#   Anthropic:    https://api.anthropic.com
#   LiteLLM:      http://localhost:4000
MYCLY_INFERENCE_URL=http://localhost:11434

# Model name as known by the backend
MYCLY_MODEL=qwen3.5:35b-a3b

# API key (required for cloud backends, often "dummy" for local Ollama)
MYCLY_API_KEY=dummy

# ---- Optional: Additional Backends ----
# Uncomment and configure as needed
# MYCLY_CORPORATE_URL=
# MYCLY_CORPORATE_KEY=
# MYCLY_CLOUD_URL=
# MYCLY_CLOUD_KEY=

# ---- Paths ----
# Override default ~/.mycly location
# MYCLY_HOME=~/.mycly

# ---- Debug ----
# Set to 1 for verbose output
# MYCLY_DEBUG=1
